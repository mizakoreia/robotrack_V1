#!/usr/bin/env bash
set -Eeuo pipefail

# Configurações padrão (personalizáveis via env)
# Em produção normalmente usamos a porta 80 ou upstream
# Mas para o bin/prod manteremos defaults compatíveis com teste local ou docker
RAILS_PORT="${RAILS_PORT:-3000}"
VITE_PORT="${VITE_PORT:-5173}"
RAILS_ENV="${RAILS_ENV:-production}"
SKIP_BUILD="${SKIP_BUILD:-0}" # defina 1 para pular build do front/assets

pids=()
names=()

log() {
  printf "\033[1;36m[prod]\033[0m %s\n" "$*"
}

err() {
  printf "\033[1;31m[prod]\033[0m %s\n" "$*" >&2
}

cleanup() {
  trap - INT TERM EXIT
  log "Encerrando serviços de produção…"
  for pid in "${pids[@]}"; do
    kill -INT "$pid" 2>/dev/null || true
  done
  sleep 1
  for pid in "${pids[@]}"; do
    kill -TERM "$pid" 2>/dev/null || true
  done
  wait || true
  log "Todos finalizados."
}

trap 'cleanup; exit 0' INT TERM
trap cleanup EXIT

check_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    err "Dependência ausente: $1"
    return 1
  fi
}

preflight() {
  check_cmd bash || exit 1
  check_cmd ruby || exit 1
  check_cmd bundle || exit 1
  check_cmd node || exit 1
  
  # Precisamos do npx para rodar o 'serve' se não tivermos nginx configurado
  check_cmd npx || exit 1 
  
  if [ -z "${SECRET_KEY_BASE:-}" ] && [ ! -f "backend/config/credentials.production.key" ] && [ ! -f "backend/config/master.key" ]; then
    log "\033[1;33m[AVISO]\033[0m SECRET_KEY_BASE não encontrada. O Rails pode falhar em produção se não estiver configurado."
  fi
}

build() {
  if [ "$SKIP_BUILD" -eq 1 ]; then
    log "Pulando etapa de build (SKIP_BUILD=1)..."
    return
  fi

  log "Compilando Frontend (vite build)..."
  (
    cd frontend
    if command -v pnpm >/dev/null 2>&1; then
      pnpm install --silent
      VITE_API_URL="${VITE_API_URL:-http://localhost:${RAILS_PORT}}" pnpm run build
    else
      npm install --silent
      VITE_API_URL="${VITE_API_URL:-http://localhost:${RAILS_PORT}}" npm run build
    fi
  )

  log "Precompilando Assets do Backend (rails assets:precompile)..."
  # Nota: Em API-only muitas vezes não precisa, mas se usar ActionCable ou Mailers com templates, pode precisar.
  # Se for puramente API sem views, pode comentar/remover ou deixar falhar silenciosamente se não tiver assets.
  (
    cd backend
    bundle check >/dev/null 2>&1 || bundle install --without development test
    RAILS_ENV="$RAILS_ENV" bundle exec rails assets:precompile || true # Não falhar se não houver assets pipeline
  )
}

start_backend() {
  log "Iniciando Rails (Puma) em :${RAILS_PORT} [${RAILS_ENV}]…"
  (
    cd backend
    # Puma em config/puma.rb lê ENV['PORT']
    PORT="$RAILS_PORT" RAILS_ENV="$RAILS_ENV" FORCE_SSL="false" bundle exec puma -C config/puma.rb 2>&1 | sed -e 's/^/[backend] /'
  ) &
  pids+=("$!")
  names+=("backend")
}

start_sidekiq() {
  log "Iniciando Sidekiq [${RAILS_ENV}]…"
  (
    cd backend
    RAILS_ENV="$RAILS_ENV" bundle exec sidekiq -C config/sidekiq.yml 2>&1 | sed -e 's/^/[sidekiq] /'
  ) &
  pids+=("$!")
  names+=("sidekiq")
}

start_frontend() {
  log "Servindo Frontend estático em :${VITE_PORT}…"
  (
    cd frontend
    # npx serve:
    # -s: Single-Page Application (reescreve 404 para index.html)
    # -l: Listen port
    # dist: pasta de build
    npx serve -s dist -l "${VITE_PORT}" 2>&1 | sed -e 's/^/[frontend] /'
  ) &
  pids+=("$!")
  names+=("frontend")
}

monitor() {
  log "Backend (API): http://localhost:${RAILS_PORT}"
  log "Frontend (SPA): http://localhost:${VITE_PORT}"
  log "Pressione Ctrl+C para encerrar."
  
  if wait -n 2>/dev/null; then
    : # Um processo morreu
  else
    wait
  fi
}

main() {
  preflight
  build
  start_backend
  start_sidekiq
  start_frontend
  monitor
}

main
