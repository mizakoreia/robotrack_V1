# Backend Environment Variables — RoboTrack
#
# Reduzido à superfície que a aplicação de fato lê. Saíram as variáveis de
# Evolution/WhatsApp, Asaas e o SMTP do magic-login, cujos módulos foram
# removidos em seal-template-baseline. As de e-mail voltam quando
# `workspace-invitations` definir template e entregabilidade.

DATABASE_URL=postgresql://robotrack_user:senha@localhost:5432/robotrack_dev
REDIS_URL=redis://localhost:6379/1

DEVISE_JWT_SECRET_KEY=***

APP_NAME=RoboTrack

# Google OAuth — único provedor de login desta base
GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
