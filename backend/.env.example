# GERADO por `bundle exec rake env:example` a partir de config/env_schema.rb.
# NÃO editar à mão — edite o schema e regenere. Sem chaves de serviços removidos do porte.

# URL do Postgres da aplicação (role robotrack_app, NOBYPASSRLS). (obrigatória em production/staging)
DATABASE_URL=postgres://robotrack_app:app_dev_pw@localhost/robotrack_dev

# Chave-base do Rails. Obrigatória fora de dev/test. (obrigatória em production/staging)
SECRET_KEY_BASE=

# Redis base; em produção é sobreposto pelas URLs por função (cache/fila/cable). (obrigatória em production/staging)
REDIS_URL=redis://localhost:6379/1

# URL pública do WebSocket (wss://.../cable). SEM default em produção. (obrigatória em production/staging)
ACTION_CABLE_URL=

# Origens permitidas, separadas por vírgula. (obrigatória em production/staging)
CORS_ORIGINS=

# Redireciona http→https. Default ligado. (opcional)
FORCE_SSL=true

# SameSite dos cookies (lax/strict/none). (opcional)
COOKIES_SAME_SITE=lax

# Threads por processo Puma (= pool do Postgres). (opcional)
RAILS_MAX_THREADS=10

# Se presente, loga em STDOUT (coleta por plataforma). (opcional)
RAILS_LOG_TO_STDOUT=

# Serve estáticos pela app quando não há CDN. (opcional)
RAILS_SERVE_STATIC_FILES=
