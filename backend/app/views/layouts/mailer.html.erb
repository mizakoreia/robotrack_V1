<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= ENV.fetch('APP_NAME', 'robotrack') %></title>
    <style>
      body { font-family: Arial, sans-serif; background: #f4f5f7; margin: 0; padding: 0; }
      .container { max-width: 640px; margin: 0 auto; padding: 24px; }
      .card { background: #ffffff; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
      .muted { color: #6b7280; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="card">
        <%= yield %>
      </div>
      <p class="muted" style="text-align:center; margin-top: 16px;">
        <%= ENV.fetch('APP_NAME', 'robotrack') %>
      </p>
    </div>
  </body>
  </html>