#!/usr/bin/env bash
#
# backup_users — dump lógico da tabela `users` ANTES da migration destrutiva
# (identity-and-auth, tarefa 1.1). A migration 1.3 remove `users.jti` e derruba o
# NOT NULL/FK de `users.user_type_id`; sem este dump, rodá-la em um banco com
# dados torna a remoção de `jti` irreversível na prática.
#
# O dump vai para backend/tmp/backups/ (gitignored — NENHUM dump entra em commit).
# Conecta como `robotrack_migrator` (dono da tabela). Ver db/PROVISIONING.md.
#
# Uso:
#   bin/backup_users [DATABASE_URL]
#
# Restauração (num banco descartável, para conferir o dump):
#   createdb -U robotrack_user robotrack_restore_check
#   psql "postgres://robotrack_migrator:mig_dev_pw@localhost/robotrack_restore_check" \
#     -f backend/tmp/backups/<arquivo>.sql
set -euo pipefail

DB_URL="${1:-${DATABASE_URL:-postgres://robotrack_migrator:mig_dev_pw@localhost/robotrack_dev}}"
DEST_DIR="$(cd "$(dirname "$0")/.." && pwd)/tmp/backups"
mkdir -p "$DEST_DIR"

STAMP="$(date +%Y%m%d_%H%M%S)"
OUT="$DEST_DIR/users_${STAMP}.sql"

echo "→ Dump lógico de users (data-only) de ${DB_URL%%\?*} ..."
pg_dump --table=users --data-only --column-inserts "$DB_URL" > "$OUT"

echo "✓ Dump salvo em: $OUT"
echo "  ($(wc -l < "$OUT") linhas)"
