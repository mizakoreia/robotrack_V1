# Frontend Environment Variables
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/cable
VITE_APP_NAME=robotrack
VITE_APP_VERSION=1.0.0

# Theme Configuration
VITE_DEFAULT_THEME=dark

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true
# realtime-collaboration 9.1 — tempo real (WorkspaceChannel + polling). Default
# LIGADO; "false" desliga TODO o cliente de tempo real deixando a aplicação
# correta, só não ao vivo — rollback vira toggle, não redeploy.
VITE_REALTIME_ENABLED=true

# Google API Key
VITE_GOOGLE_API_KEY=***

# Build Configuration
VITE_BUILD_MODE=development
